# ===== 被评测模型的 API 地址 =====
# 方案一：vLLM / 标准 OpenAI 兼容 API（默认）
EVAL_MODEL_API_BASE=http://172.17.209.125:8000/v1
EVAL_MODEL_API_KEY=
EVAL_MODEL_NAME=qwen3.5-4b-4bit
EVAL_MODEL_TYPE=openai          # openai（默认）| ollama

# 方案二：Ollama 部署的模型（取消注释以下 3 行即可切换）
# EVAL_MODEL_TYPE=ollama
# EVAL_MODEL_API_BASE=http://localhost:11434   # Ollama 默认地址
# EVAL_MODEL_NAME=llama3.2                     # 用 `ollama list` 查看已拉取的模型

# ===== 可选：评测执行参数 =====
EVAL_CONCURRENCY=10
EVAL_TIMEOUT=120

# ===== Judge 模型（评测回答质量时使用，可和被评测模型共用） =====
# 默认复用评测模型。如需独立 Judge，取消注释以下配置：
JUDGE_MODEL_API_BASE=http://172.17.209.125:8000/v1
JUDGE_MODEL_API_KEY=
JUDGE_MODEL_NAME=qwen3.5-4b-4bit
# JUDGE_MODEL_TYPE=openai   # openai（默认）| ollama

# ===== RAG 系统端点（P1 阶段） =====
RAG_API_BASE=http://192.168.1.100:8080/ask
RAG_API_KEY=

# ===== 系统内部（默认使用项目根目录下的 results/，可注释掉或修改） =====
# EVAL_DB_PATH=results/eval.db
# EVAL_RESULTS_DIR=results
# EVAL_REPORTS_DIR=results/reports
LOG_LEVEL=INFO
