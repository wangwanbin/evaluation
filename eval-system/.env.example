# ===== 必需：被评测模型的 API 地址 =====
EVAL_MODEL_API_BASE=http://192.168.1.100:8000/v1
EVAL_MODEL_API_KEY=
EVAL_MODEL_NAME=qwen2.5-72b

# ===== 可选：评测执行参数 =====
EVAL_CONCURRENCY=10
EVAL_TIMEOUT=120

# ===== Judge 模型（评测回答质量时使用，可和被评测模型共用） =====
JUDGE_MODEL_API_BASE=http://192.168.1.100:8000/v1
JUDGE_MODEL_API_KEY=
JUDGE_MODEL_NAME=qwen2.5-72b

# ===== RAG 系统端点（P1 阶段） =====
RAG_API_BASE=http://192.168.1.100:8080/ask
RAG_API_KEY=

# ===== 系统内部 =====
EVAL_DB_PATH=/app/results/eval.db
EVAL_RESULTS_DIR=/app/results/runs
EVAL_REPORTS_DIR=/app/results/reports
LOG_LEVEL=INFO
